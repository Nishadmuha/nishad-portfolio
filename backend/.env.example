# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB Atlas Connection URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Security (JWT token signing secret)
JWT_SECRET=your_super_secret_jwt_key

# CORS Settings (URL of the frontend in production, e.g. Vercel)
CLIENT_URL=https://your-portfolio-frontend.vercel.app

# Cloudinary Configuration (Optional for local dev, Required for Render production uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
